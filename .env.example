# AURORA 配置示例
# 将此文件复制为 .env 并填入您的配置

# ============================================
# 最小本地运行配置
# ============================================

# 默认使用百炼真实服务
AURORA_LLM_PROVIDER=bailian
AURORA_EMBEDDING_PROVIDER=bailian
AURORA_DATA_DIR=./data

# ============================================
# 火山方舟 (Volcengine Ark) LLM 配置
# ============================================

# 需要切换到火山方舟时再改成 ark
# AURORA_LLM_PROVIDER=ark

# 阿里云百炼 LLM API Key
AURORA_BAILIAN_LLM_API_KEY=

# 百炼文本模型
AURORA_BAILIAN_LLM_MODEL=qwen3.5-plus

# 百炼 LLM OpenAI 兼容 API 基础 URL
AURORA_BAILIAN_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 需要火山方舟时再填
AURORA_ARK_API_KEY=
AURORA_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AURORA_ARK_LLM_MODEL=doubao-seed-1-8-251228

# LLM 请求超时 (秒)
AURORA_LLM_TIMEOUT=60.0

# LLM 最大重试次数
AURORA_LLM_MAX_RETRIES=3

# ============================================
# 阿里云百炼 (Alibaba Bailian) 嵌入配置
# ============================================

# 阿里云百炼嵌入模型
AURORA_BAILIAN_EMBEDDING_MODEL=text-embedding-v4

# 阿里云百炼嵌入 API Key
AURORA_BAILIAN_EMBEDDING_API_KEY=

# 百炼嵌入 OpenAI 兼容 API 基础 URL
AURORA_BAILIAN_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================
# 运行时配置
# ============================================

# 嵌入维度 (与嵌入模型匹配)
# 百炼 `text-embedding-v4` 默认使用 1024
AURORA_DIM=1024

# 嵌入缓存开关
AURORA_EMBEDDING_CACHE_ENABLED=true

# 嵌入缓存大小
AURORA_EMBEDDING_CACHE_SIZE=10000

# ============================================
# 隐私配置
# ============================================

# PII 脱敏开关
AURORA_PII_REDACTION_ENABLED=true

# ============================================
# 事件溯源配置
# ============================================

# 快照间隔 (每 N 个事件保存一次快照)
AURORA_SNAPSHOT_EVERY_EVENTS=200

# 可重复性随机种子
AURORA_MEMORY_SEED=42

# ============================================
# 算法核心配置
# ============================================

# 最大 Plot 数量
AURORA_MAX_PLOTS=5000

# KDE 蓄水池大小
AURORA_KDE_RESERVOIR=4096

# Story CRP 浓度参数
AURORA_STORY_ALPHA=1.0

# Theme CRP 浓度参数
AURORA_THEME_ALPHA=0.5
