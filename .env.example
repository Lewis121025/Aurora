# AURORA 配置示例
# 将此文件复制为 .env 并填入您的配置

# ============================================
# 火山方舟 (Volcengine Ark) LLM 配置
# ============================================

# LLM 提供者: "ark" (火山方舟) 或 "mock" (本地测试)
AURORA_LLM_PROVIDER=ark

# 火山方舟 API Key (必填)
AURORA_ARK_API_KEY=your-ark-api-key-here

# API 基础 URL (可选，默认北京区)
AURORA_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# LLM 模型 (可选)
# 推荐: doubao-1-5-pro-32k-250115 (高质量)
#       doubao-1-5-lite-32k-250115 (快速)
AURORA_ARK_LLM_MODEL=doubao-1-5-pro-32k-250115

# LLM 请求超时 (秒)
AURORA_LLM_TIMEOUT=60.0

# LLM 最大重试次数
AURORA_LLM_MAX_RETRIES=3

# ============================================
# 阿里云百炼 (Alibaba Bailian) 嵌入配置
# ============================================

# 嵌入提供者: "bailian" | "ark" | "local" | "hash"
AURORA_EMBEDDING_PROVIDER=local

# 阿里云百炼 API Key (必填)
AURORA_BAILIAN_API_KEY=your-bailian-api-key-here

# 阿里云百炼嵌入模型
AURORA_BAILIAN_EMBEDDING_MODEL=text-embedding-v4

# 阿里云百炼 API 基础 URL
AURORA_BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================
# 运行时配置
# ============================================

# 数据存储目录
AURORA_DATA_DIR=./data

# 嵌入维度 (与嵌入模型匹配)
# text-embedding-v3: 1024 (默认)
AURORA_DIM=1024

# 嵌入缓存开关
AURORA_EMBEDDING_CACHE_ENABLED=true

# 嵌入缓存大小
AURORA_EMBEDDING_CACHE_SIZE=10000

# ============================================
# 隐私配置
# ============================================

# PII 脱敏开关
AURORA_PII_REDACTION_ENABLED=true

# ============================================
# 事件溯源配置
# ============================================

# 快照间隔 (每 N 个事件保存一次快照)
AURORA_SNAPSHOT_EVERY_EVENTS=200

# ============================================
# 算法核心配置
# ============================================

# 最大 Plot 数量
AURORA_MAX_PLOTS=5000

# KDE 蓄水池大小
AURORA_KDE_RESERVOIR=4096

# Story CRP 浓度参数
AURORA_STORY_ALPHA=1.0

# Theme CRP 浓度参数
AURORA_THEME_ALPHA=0.5
